generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model BookingService {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  description       String
  durationMinutes   Int
  bufferMinutes     Int                @default(15)
  price             Float?
  colorHex          String             @default("#6B3FA0")
  emoji             String             @default("*")
  isActive          Boolean            @default(true)
  maxPerSlot        Int                @default(1)
  createdAt         DateTime           @default(now())
  appointments      Appointment[]
  availabilityRules AvailabilityRule[]
}

model AvailabilityRule {
  id        String          @id @default(cuid())
  serviceId String?
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean         @default(true)
  service   BookingService? @relation(fields: [serviceId], references: [id])
}

model AvailabilityException {
  id        String   @id @default(cuid())
  date      DateTime
  isOpen    Boolean
  startTime String?
  endTime   String?
  reason    String?
  createdAt DateTime @default(now())
}

model Appointment {
  id                String         @id @default(cuid())
  serviceId         String
  clientName        String
  clientEmail       String
  clientPhone       String?
  date              DateTime
  startTime         String
  endTime           String
  status            String         @default("pending")
  notes             String?
  googleEventId     String?
  confirmationToken String         @unique @default(cuid())
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  service           BookingService @relation(fields: [serviceId], references: [id])
}

model AdminUser {
  id             String   @id @default(cuid())
  email          String   @unique
  hashedPassword String
  name           String
  createdAt      DateTime @default(now())
}

model BookingSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ════════════════════════════════════════════════════════════════
// CATÉGORIES DE PRODUITS — gérées dynamiquement + sync Clover
// ════════════════════════════════════════════════════════════════
// Remplace l'ancienne liste hardcodée. Le champ Product.category
// reste un String (slug) pour préserver la compatibilité avec
// deriveCategory() et mapSiteToCloverCategoryIds(). La liaison
// logique se fait via Category.slug ↔ Product.category.
// ════════════════════════════════════════════════════════════════

model Category {
  id               String    @id @default(cuid())
  slug             String    @unique
  name             String
  description      String    @default("")
  cloverCategoryId String?   @unique
  displayOrder     Int       @default(0)
  cloverSyncedAt   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([displayOrder])
}

// ════════════════════════════════════════════════════════════════
// MENU DE NAVIGATION — géré dynamiquement depuis /admin/site/menu
//  location : HEADER (barre du haut) | FOOTER (colonne « Navigation » du pied)
//  type     : PAGE (page interne du site) | CUSTOM (lien libre)
//  isVisible : false = en réserve (masqué du site, conservé en admin)
// ════════════════════════════════════════════════════════════════
model MenuItem {
  id           String   @id @default(cuid())
  label        String
  href         String
  type         String   @default("PAGE")
  location     String   @default("HEADER")
  isVisible    Boolean  @default(true)
  openInNewTab Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([location, sortOrder])
}

model Product {
  id               String    @id @default(cuid())
  slug             String    @unique
  name             String
  price            Float
  description      String
  longDescription  String    @default("")
  category         String
  image            String
  images           String[]  @default([])
  inStock          Boolean   @default(true)
  featured         Boolean   @default(false)
  tags             String[]  @default([])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  stone            String?
  subcategory      String?
  author           String?
  content          String?
  format           String?
  checkoutType     String    @default("stripe")
  // Intégration Clover POS — sync inventaire physique
  cloverId         String?   @unique // ID de l'item dans Clover
  sku              String? // Stock Keeping Unit (fallback de matching)
  stockQuantity    Int? // Stock numérique (null = stock illimité ou non géré)
  cloverSyncedAt   DateTime? // Dernière synchronisation depuis Clover
  // Type de produit + sync Clover opt-out
  productType      String    @default("PHYSICAL") // PHYSICAL | DROPSHIPPING | EBOOK | COURSE
  syncToClover     Boolean   @default(true) // false = produit jamais envoyé à Clover (dropshipping, virtuel)
  // Livraison digitale (productType = EBOOK ou COURSE)
  downloadUrl      String? // Pour EBOOK : URL du fichier dans Supabase Storage (signé après paiement)
  courseAccessSlug String? // Pour COURSE : slug du cours pour accès au lecteur vidéo

  @@index([cloverId])
  @@index([sku])
  @@index([productType])
}

// ════════════════════════════════════════════════════════════════
// CLOVER — Historique des synchronisations d'inventaire
// ════════════════════════════════════════════════════════════════

model CloverSyncLog {
  id           String    @id @default(cuid())
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  status       String    @default("RUNNING") // RUNNING | SUCCESS | PARTIAL | FAILED
  mode         String    @default("apply") // dry-run | apply
  triggeredBy  String    @default("manual") // manual | cron
  itemsFetched Int       @default(0)
  itemsCreated Int       @default(0)
  itemsUpdated Int       @default(0)
  itemsSkipped Int       @default(0)
  errorsCount  Int       @default(0)
  errorMessage String?
  details      String? // JSON sérialisé : { errors: [], unmatched: [] }

  @@index([startedAt])
  @@index([status])
}

// ════════════════════════════════════════════════════════════════
// CLOVER — Retry queue pour les opérations qui ont échoué
// ════════════════════════════════════════════════════════════════
// Si la création/update/delete d'un produit côté Clover échoue (API down,
// permission manquante, etc.), l'opération est mise en queue pour re-essai
// automatique avec backoff exponential.
// ════════════════════════════════════════════════════════════════

model CloverSyncQueue {
  id            String    @id @default(cuid())
  productId     String // FK logique vers Product.id (pas de FK contrainte pour éviter les blocages)
  action        String // CREATE | UPDATE | DELETE | STOCK_DECREMENT | STOCK_INCREMENT
  payload       String // JSON sérialisé : données nécessaires à l'opération
  status        String    @default("PENDING") // PENDING | PROCESSING | SUCCESS | FAILED_RETRYING | FAILED_MAX_ATTEMPTS
  attempts      Int       @default(0)
  maxAttempts   Int       @default(5)
  lastError     String?
  nextAttemptAt DateTime  @default(now())
  lastAttemptAt DateTime?
  succeededAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, nextAttemptAt]) // critique pour le cron
  @@index([productId])
  @@index([createdAt])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  type            String
  status          String      @default("new")
  deliveryMethod  String      @default("pickup")
  customerName    String
  customerEmail   String
  customerPhone   String?
  customerMessage String?
  shippingAddress String?
  subtotal        Float
  shippingCost    Float?
  total           Float
  stripeSessionId String?     @unique
  stripePaymentId String?
  paidAt          DateTime?
  notes           String?     @default("")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String?
  productName String
  price       Float
  quantity    Int
  image       String?
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ════════════════════════════════════════════════════════════════
// PLATEFORME DE SOINS HOLISTIQUES
// ════════════════════════════════════════════════════════════════

model HolisticUser {
  id                String                 @id @default(cuid())
  email             String                 @unique
  hashedPassword    String
  role              String                 @default("CLIENT") // CLIENT | PRACTITIONER | ADMIN
  firstName         String
  lastName          String
  phone             String?
  locale            String                 @default("fr")
  // Décharge électronique LCCJTI
  dischargeSignedAt DateTime?
  dischargeIp       String?
  dischargeHash     String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  practitioner      Practitioner?
  clientBookings    HolisticAppointment[]  @relation("ClientAppointments")
  reviews           HolisticReview[]
  notifications     HolisticNotification[]
}

model Practitioner {
  id                 String                 @id @default(cuid())
  userId             String                 @unique
  user               HolisticUser           @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug               String                 @unique
  status             String                 @default("PENDING") // PENDING | APPROVED | REJECTED | SUSPENDED
  bio                String                 @default("")
  specialties        String[]               @default([])
  yearsExperience    Int                    @default(0)
  hourlyRate         Float                  @default(80)
  photoUrl           String?
  stripeAccountId    String?
  stripeAccountReady Boolean                @default(false)
  certificationUrls  String[]               @default([])
  insuranceUrl       String?
  insuranceNumber    String?
  adminNote          String?
  approvedAt         DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  // V2 — plateforme unifiée (additifs, défauts safe)
  isOwner            Boolean                @default(false)
  commissionPct      Float                  @default(35)
  addressLine        String?
  city               String?
  postalCode         String?
  userV2Id           String?                @unique
  userV2             User?                  @relation(fields: [userV2Id], references: [id])
  // Relations existantes (legacy, à ne pas casser)
  availabilities     HolisticAvailability[]
  appointments       HolisticAppointment[]  @relation("PractitionerAppointments")
  reviews            HolisticReview[]
  pendingChanges     PendingPractitionerChange[]
  // Relations V2 (nouveaux modèles)
  offerings          Offering[]
  offeringProviders  OfferingProvider[]     @relation("OfferingProviders")
  schedule           Availability[]
  bookings           Booking[]              @relation("PractitionerBookings")
  bookingReviews     Review[]               @relation("PractitionerBookingReviews")
}

// Demandes de modification de profil / disponibilités soumises par le praticien
// et nécessitant l'approbation d'un admin. Le profil/dispos en cours restent
// visibles publiquement jusqu'à approbation.
model PendingPractitionerChange {
  id             String       @id @default(cuid())
  practitionerId String
  practitioner   Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)
  type           String       // PROFILE | AVAILABILITY
  // Payload JSON des changements demandés. Pour PROFILE : { bio?, specialties?, yearsExperience?, hourlyRate?, photoUrl?, firstName?, lastName? }
  // Pour AVAILABILITY : { blocks: [{ dayOfWeek, startTime, endTime, isActive }] } — remplace l'ensemble
  payload        Json
  status         String       @default("PENDING") // PENDING | APPROVED | REJECTED
  requestedAt    DateTime     @default(now())
  reviewedAt     DateTime?
  reviewedById   String?      // adminUserId de celui qui a tranché
  adminNote      String?      // raison du rejet, commentaire, etc.

  @@index([practitionerId, status])
  @@index([status, requestedAt])
}

model HolisticAvailability {
  id             String       @id @default(cuid())
  practitionerId String
  practitioner   Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)
  dayOfWeek      Int // 0=Dimanche, 1=Lundi, ..., 6=Samedi
  // null = créneau hebdomadaire récurrent ; sinon = disponibilité PONCTUELLE à cette date précise
  date           DateTime?
  startTime      String // "09:00"
  endTime        String // "17:00"
  isActive       Boolean      @default(true)

  @@index([practitionerId, date])
}

model HolisticAppointment {
  id             String                 @id @default(cuid())
  clientId       String
  client         HolisticUser           @relation("ClientAppointments", fields: [clientId], references: [id])
  practitionerId String
  practitioner   Practitioner           @relation("PractitionerAppointments", fields: [practitionerId], references: [id])
  startsAt       DateTime
  endsAt         DateTime
  status         String                 @default("PENDING") // PENDING | CONFIRMED | CANCELLED | COMPLETED
  dailyRoomUrl   String?
  dailyRoomName  String?
  cancelledAt    DateTime?
  cancelledBy    String? // "CLIENT" | "PRACTITIONER" | "ADMIN"
  notes          String?

  // ─── Modèle acompte + solde (Phase 2 MVP - paiement en 2 temps) ──────────
  // Pour services individuels : acompte de 25 $ à la résa, solde facturé après la séance.
  // Pour services de groupe (capacity > 1) : paiement complet à la résa, pas d'acompte.
  totalAmount             Float?    // prix total de la séance (offering.price ou hourlyRate × heures)
  depositAmount           Float?    // montant de l'acompte facturé à la résa (25 $ par défaut)
  remainingAmount         Float?    // ce qu'il reste à facturer (totalAmount - depositAmount)
  stripeCustomerId        String?   // Stripe Customer ID — pour réutiliser la carte
  stripePaymentMethodId   String?   // PaymentMethod ID sauvegardé — pour charger le solde off-session
  depositPaidAt           DateTime? // moment où l'acompte a été reçu (webhook Stripe)
  remainderChargedAt      DateTime? // moment où le solde a été chargé (clic praticienne)
  remainderPaymentIntentId String?  // PaymentIntent ID du paiement du solde (pour reçu)
  completionOutcome       String?   // CHARGED | GIFTED | NO_SHOW (set quand la praticienne clique « Terminer »)

  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  payment        HolisticPayment?
  review         HolisticReview?
  notifications  HolisticNotification[]
}

model HolisticPayment {
  id                    String              @id @default(cuid())
  appointmentId         String              @unique
  appointment           HolisticAppointment @relation(fields: [appointmentId], references: [id])
  stripePaymentIntentId String?
  stripeTransferId      String?
  amountTotal           Float
  amountCommission      Float // 35%
  amountPractitioner    Float // 65%
  status                String              @default("PENDING") // PENDING | PAID | REFUNDED | FAILED
  paidAt                DateTime?
  payoutAt              DateTime?
  createdAt             DateTime            @default(now())
}

model HolisticReview {
  id             String              @id @default(cuid())
  appointmentId  String              @unique
  appointment    HolisticAppointment @relation(fields: [appointmentId], references: [id])
  clientId       String
  client         HolisticUser        @relation(fields: [clientId], references: [id])
  practitionerId String
  practitioner   Practitioner        @relation(fields: [practitionerId], references: [id])
  rating         Int // 1-5
  comment        String?
  status         String              @default("PENDING") // PENDING | APPROVED | REJECTED
  submittedAt    DateTime            @default(now())
  approvedAt     DateTime?
}

model HolisticNotification {
  id            String               @id @default(cuid())
  userId        String
  user          HolisticUser         @relation(fields: [userId], references: [id])
  appointmentId String?
  appointment   HolisticAppointment? @relation(fields: [appointmentId], references: [id])
  type          String // BOOKING_CONFIRM | REMINDER_24H | REMINDER_1H | VIDEO_LINK | CANCELLATION | PAYOUT
  channel       String // EMAIL | SMS
  sentAt        DateTime?
  status        String               @default("PENDING") // PENDING | SENT | FAILED
  createdAt     DateTime             @default(now())
}

// ════════════════════════════════════════════════════════════════
// PLATEFORME UNIFIÉE V2 — Auth + Réservations soins/cours
// ════════════════════════════════════════════════════════════════
// Ces modèles coexistent avec les anciens (AdminUser, HolisticUser,
// BookingService, Appointment, HolisticAppointment, HolisticPayment,
// AvailabilityRule, HolisticAvailability) le temps du backfill.
// ════════════════════════════════════════════════════════════════

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  hashedPassword    String
  role              String         @default("CLIENT") // CLIENT | PRACTITIONER | ADMIN
  firstName         String
  lastName          String
  phone             String?
  locale            String         @default("fr")
  // Décharge électronique LCCJTI (préservé depuis HolisticUser)
  dischargeSignedAt DateTime?
  dischargeIp       String?
  dischargeHash     String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  practitioner      Practitioner?
  clientBookings    Booking[]      @relation("ClientBookings")
  reviews           Review[]
  notifications     Notification[]
}

model Offering {
  id              String       @id @default(cuid())
  // Praticien "principal/propriétaire" du service. Le client peut aussi en
  // choisir un autre via la relation many-to-many `providers` ci-dessous.
  practitionerId  String
  practitioner    Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)
  type            String // SOIN | COURS | CEREMONIE | GUIDANCE | ATELIER | CONSULTATION | SERVICE_EXTERIEUR | ... (libre)
  slug            String       @unique
  name            String
  description     String
  longDescription String       @default("")
  durationMinutes Int
  bufferMinutes   Int          @default(15)
  // Prix : à la carte (par personne), pour 2 personnes (duo), package complet
  price            Float        // prix de base à la carte / par personne
  priceForTwo      Float?       // tarif spécial pour duo (couple, ami·e, etc.)
  pricePackage     Float?       // forfait complet (ex: pack de N cours)
  pricePackageMsrp Float?       // valeur d'origine du forfait (pour afficher l'économie)
  numSessions      Int?         // nombre de séances dans le forfait (ex: 20 cours)
  currency         String       @default("CAD")
  modes            String[]     @default(["IN_PERSON"]) // IN_PERSON | VIRTUAL
  capacity         Int          @default(1)
  colorHex         String       @default("#6B3FA0")
  emoji            String       @default("*")
  imageUrl         String?
  features         String[]     @default([])
  isActive         Boolean      @default(true)
  isFeatured       Boolean      @default(false)
  sortOrder        Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  bookings         Booking[]
  // Praticien·ne·s additionnel·le·s pouvant offrir ce service (en plus du primaire)
  providers        OfferingProvider[]
  // Catégorie (gérée dans /admin/site/categories) — une seule par service
  categoryId       String?
  category         ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([type, isActive, isFeatured])
  @@index([practitionerId, isActive])
  @@index([categoryId])
}

// ════════════════════════════════════════════════════════════════
// CATÉGORIES DE SERVICES — gérées dans /admin/site/categories
//  Hiérarchie 2 niveaux : parentId == null => catégorie principale, sinon
//  sous-catégorie. showOnHome => affichée comme slider sur l'accueil.
//  Chaque Offering appartient à UNE seule catégorie (Offering.categoryId).
// ════════════════════════════════════════════════════════════════
model ServiceCategory {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String            @default("")
  emoji       String            @default("")
  // Pont vers le champ technique Offering.type (SOIN, COURS, ATELIER, …) afin
  // de garder /seances et /ecole fonctionnels sans champ « type » dans le form.
  typeCode    String?
  parentId    String?
  parent      ServiceCategory?  @relation("ServiceCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    ServiceCategory[] @relation("ServiceCategoryTree")
  sortOrder   Int               @default(0)
  showOnHome  Boolean           @default(false)
  isActive    Boolean           @default(true)
  offerings   Offering[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([parentId, sortOrder])
}

// ════════════════════════════════════════════════════════════════
// SLIDERS DE L'ACCUEIL — gérés dans /admin/site/sliders
//  Titre libre + liste de catégories/sous-catégories (categoryIds). Le slider
//  affiche les services rattachés à ces catégories (et à leurs sous-catégories).
// ════════════════════════════════════════════════════════════════
model HomeSlider {
  id          String   @id @default(cuid())
  title       String
  categoryIds String[] @default([])
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
}

// Table de liaison many-to-many entre Offering et Practitioner.
// Permet à plusieurs praticien·ne·s d'offrir le même service.
// Le `practitionerId` sur Offering reste le "propriétaire/primaire".
model OfferingProvider {
  id             String       @id @default(cuid())
  offeringId     String
  offering       Offering     @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  practitionerId String
  practitioner   Practitioner @relation("OfferingProviders", fields: [practitionerId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([offeringId, practitionerId])
  @@index([practitionerId])
}

model Availability {
  id             String       @id @default(cuid())
  practitionerId String
  practitioner   Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)
  dayOfWeek      Int // 0=Dim ... 6=Sam
  startTime      String // "09:00"
  endTime        String // "17:00"
  mode           String? // null = tous modes, sinon IN_PERSON ou VIRTUAL
  isActive       Boolean      @default(true)

  @@index([practitionerId, dayOfWeek, isActive])
}

model Booking {
  id                String         @id @default(cuid())
  offeringId        String
  offering          Offering       @relation(fields: [offeringId], references: [id])
  practitionerId    String
  practitioner      Practitioner   @relation("PractitionerBookings", fields: [practitionerId], references: [id])
  clientId          String
  client            User           @relation("ClientBookings", fields: [clientId], references: [id])
  startsAt          DateTime
  endsAt            DateTime
  mode              String // IN_PERSON | VIRTUAL
  status            String         @default("PENDING_PAYMENT") // PENDING_PAYMENT | CONFIRMED | CANCELLED | COMPLETED | NO_SHOW
  notes             String?
  dailyRoomUrl      String? // si VIRTUAL
  dailyRoomName     String?
  locationSnapshot  String? // snapshot adresse si IN_PERSON
  googleEventId     String? // sync Google Calendar Noctura
  cancelledAt       DateTime?
  cancelledBy       String? // CLIENT | PRACTITIONER | ADMIN
  confirmationToken String         @unique @default(cuid())
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  payment           Payment?
  review            Review?
  notifications     Notification[]

  @@index([practitionerId, startsAt, endsAt, status]) // CRITIQUE — vérif conflit unifiée O(log n)
  @@index([clientId, startsAt])
}

model Payment {
  id                    String    @id @default(cuid())
  bookingId             String    @unique
  booking               Booking   @relation(fields: [bookingId], references: [id])
  stripeSessionId       String?   @unique
  stripePaymentIntentId String?
  stripeTransferId      String? // null pour Noctura (compte principal)
  amountTotal           Float
  amountCommission      Float // 0 pour Noctura, 35% pour autres
  amountPractitioner    Float // total - commission
  commissionPct         Float
  currency              String    @default("CAD")
  status                String    @default("PENDING") // PENDING | PAID | REFUNDED | FAILED
  paidAt                DateTime?
  refundedAt            DateTime?
  payoutAt              DateTime?
  createdAt             DateTime  @default(now())
}

model Review {
  id             String       @id @default(cuid())
  bookingId      String       @unique
  booking        Booking      @relation(fields: [bookingId], references: [id])
  clientId       String
  client         User         @relation(fields: [clientId], references: [id])
  practitionerId String
  practitioner   Practitioner @relation("PractitionerBookingReviews", fields: [practitionerId], references: [id])
  rating         Int // 1-5
  comment        String?
  status         String       @default("PENDING") // PENDING | APPROVED | REJECTED
  submittedAt    DateTime     @default(now())
  approvedAt     DateTime?

  @@index([practitionerId, status])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  bookingId String?
  booking   Booking?  @relation(fields: [bookingId], references: [id])
  type      String // BOOKING_CONFIRM | REMINDER_24H | REMINDER_1H | VIDEO_LINK | CANCELLATION | PAYOUT
  channel   String // EMAIL | SMS
  sentAt    DateTime?
  status    String    @default("PENDING") // PENDING | SENT | FAILED
  createdAt DateTime  @default(now())

  @@index([userId, status])
}

// ════════════════════════════════════════════════════════════════
// INFOLETTRE — Abonnés newsletter (séparé des comptes utilisateurs)
// ════════════════════════════════════════════════════════════════
// Une personne peut s'abonner à l'infolettre SANS créer de compte client.
// Conforme Loi 25 (Québec) et LCAP : consent explicit, IP, timestamp, désabo facile.
// ════════════════════════════════════════════════════════════════

model NewsletterSubscriber {
  id               String    @id @default(cuid())
  email            String    @unique
  firstName        String?
  lastName         String?
  phone            String?
  consentEmail     Boolean   @default(false)
  consentIp        String?
  consentedAt      DateTime?
  unsubscribedAt   DateTime?
  unsubscribeToken String    @unique @default(cuid())
  source           String    @default("infolettre") // infolettre | register | order | manual
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([unsubscribedAt])
  @@index([createdAt])
}
