generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model BookingService {
  id              String              @id @default(cuid())
  name            String
  slug            String              @unique
  description     String
  durationMinutes Int
  bufferMinutes   Int                 @default(15)
  price           Float?
  colorHex        String              @default("#6B3FA0")
  emoji           String              @default("*")
  isActive        Boolean             @default(true)
  maxPerSlot      Int                 @default(1)
  appointments    Appointment[]
  availabilityRules AvailabilityRule[]
  createdAt       DateTime            @default(now())
}

model AvailabilityRule {
  id        String          @id @default(cuid())
  serviceId String?
  service   BookingService? @relation(fields: [serviceId], references: [id])
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean         @default(true)
}

model AvailabilityException {
  id        String   @id @default(cuid())
  date      DateTime
  isOpen    Boolean
  startTime String?
  endTime   String?
  reason    String?
  createdAt DateTime @default(now())
}

model Appointment {
  id                String         @id @default(cuid())
  serviceId         String
  service           BookingService @relation(fields: [serviceId], references: [id])
  clientName        String
  clientEmail       String
  clientPhone       String?
  date              DateTime
  startTime         String
  endTime           String
  status            String         @default("pending")
  notes             String?
  googleEventId     String?
  confirmationToken String         @unique @default(cuid())
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model AdminUser {
  id             String   @id @default(cuid())
  email          String   @unique
  hashedPassword String
  name           String
  createdAt      DateTime @default(now())
}

model BookingSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Product {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  price           Float
  description     String
  longDescription String   @default("")
  category        String
  subcategory     String?
  stone           String?
  author          String?
  content         String?
  format          String?
  isbn            String?
  checkoutType    String   @default("stripe")
  image           String
  images          String[] @default([])
  inStock         Boolean  @default(true)
  featured        Boolean  @default(false)
  tags            String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  type            String
  status          String      @default("new")
  deliveryMethod  String      @default("pickup")
  customerName    String
  customerEmail   String
  customerPhone   String?
  customerMessage String?
  shippingAddress String?
  subtotal        Float
  shippingCost    Float?
  total           Float
  stripeSessionId String?     @unique
  stripePaymentId String?
  paidAt          DateTime?
  notes           String?     @default("")
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  productName String
  price       Float
  quantity    Int
  image       String?
}
