generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model BookingService {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  description       String
  durationMinutes   Int
  bufferMinutes     Int                @default(15)
  price             Float?
  colorHex          String             @default("#6B3FA0")
  emoji             String             @default("*")
  isActive          Boolean            @default(true)
  maxPerSlot        Int                @default(1)
  createdAt         DateTime           @default(now())
  appointments      Appointment[]
  availabilityRules AvailabilityRule[]
}

model AvailabilityRule {
  id        String          @id @default(cuid())
  serviceId String?
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean         @default(true)
  service   BookingService? @relation(fields: [serviceId], references: [id])
}

model AvailabilityException {
  id        String   @id @default(cuid())
  date      DateTime
  isOpen    Boolean
  startTime String?
  endTime   String?
  reason    String?
  createdAt DateTime @default(now())
}

model Appointment {
  id                String         @id @default(cuid())
  serviceId         String
  clientName        String
  clientEmail       String
  clientPhone       String?
  date              DateTime
  startTime         String
  endTime           String
  status            String         @default("pending")
  notes             String?
  googleEventId     String?
  confirmationToken String         @unique @default(cuid())
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  service           BookingService @relation(fields: [serviceId], references: [id])
}

model AdminUser {
  id             String   @id @default(cuid())
  email          String   @unique
  hashedPassword String
  name           String
  createdAt      DateTime @default(now())
}

model BookingSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Product {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  price           Float
  description     String
  longDescription String   @default("")
  category        String
  image           String
  images          String[] @default([])
  inStock         Boolean  @default(true)
  featured        Boolean  @default(false)
  tags            String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  stone           String?
  subcategory     String?
  author          String?
  content         String?
  format          String?
  isbn            String?
  checkoutType    String   @default("stripe")
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  type            String
  status          String      @default("new")
  deliveryMethod  String      @default("pickup")
  customerName    String
  customerEmail   String
  customerPhone   String?
  customerMessage String?
  shippingAddress String?
  subtotal        Float
  shippingCost    Float?
  total           Float
  stripeSessionId String?     @unique
  stripePaymentId String?
  paidAt          DateTime?
  notes           String?     @default("")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String?
  productName String
  price       Float
  quantity    Int
  image       String?
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ════════════════════════════════════════════════════════════════
// PLATEFORME DE SOINS HOLISTIQUES
// ════════════════════════════════════════════════════════════════

model HolisticUser {
  id             String         @id @default(cuid())
  email          String         @unique
  hashedPassword String
  role           String         @default("CLIENT") // CLIENT | PRACTITIONER | ADMIN
  firstName      String
  lastName       String
  phone          String?
  locale         String         @default("fr")
  // Décharge électronique LCCJTI
  dischargeSignedAt DateTime?
  dischargeIp       String?
  dischargeHash     String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  practitioner   Practitioner?
  clientBookings HolisticAppointment[] @relation("ClientAppointments")
  reviews        HolisticReview[]
  notifications  HolisticNotification[]
}

model Practitioner {
  id                 String         @id @default(cuid())
  userId             String         @unique
  user               HolisticUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug               String         @unique
  status             String         @default("PENDING") // PENDING | APPROVED | REJECTED | SUSPENDED
  bio                String         @default("")
  specialties        String[]       @default([])
  yearsExperience    Int            @default(0)
  hourlyRate         Float          @default(80)
  photoUrl           String?
  stripeAccountId    String?
  stripeAccountReady Boolean        @default(false)
  certificationUrls  String[]       @default([])
  insuranceUrl       String?
  insuranceNumber    String?
  adminNote          String?
  approvedAt         DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  availabilities     HolisticAvailability[]
  appointments       HolisticAppointment[] @relation("PractitionerAppointments")
  reviews            HolisticReview[]
}

model HolisticAvailability {
  id             String       @id @default(cuid())
  practitionerId String
  practitioner   Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)
  dayOfWeek      Int          // 0=Dimanche, 1=Lundi, ..., 6=Samedi
  startTime      String       // "09:00"
  endTime        String       // "17:00"
  isActive       Boolean      @default(true)
}

model HolisticAppointment {
  id             String       @id @default(cuid())
  clientId       String
  client         HolisticUser @relation("ClientAppointments", fields: [clientId], references: [id])
  practitionerId String
  practitioner   Practitioner @relation("PractitionerAppointments", fields: [practitionerId], references: [id])
  startsAt       DateTime
  endsAt         DateTime
  status         String       @default("PENDING") // PENDING | CONFIRMED | CANCELLED | COMPLETED
  dailyRoomUrl   String?
  dailyRoomName  String?
  cancelledAt    DateTime?
  cancelledBy    String?      // "CLIENT" | "PRACTITIONER" | "ADMIN"
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  payment        HolisticPayment?
  review         HolisticReview?
  notifications  HolisticNotification[]
}

model HolisticPayment {
  id                    String              @id @default(cuid())
  appointmentId         String              @unique
  appointment           HolisticAppointment @relation(fields: [appointmentId], references: [id])
  stripePaymentIntentId String?
  stripeTransferId      String?
  amountTotal           Float
  amountCommission      Float               // 35%
  amountPractitioner    Float               // 65%
  status                String              @default("PENDING") // PENDING | PAID | REFUNDED | FAILED
  paidAt                DateTime?
  payoutAt              DateTime?
  createdAt             DateTime            @default(now())
}

model HolisticReview {
  id             String              @id @default(cuid())
  appointmentId  String              @unique
  appointment    HolisticAppointment @relation(fields: [appointmentId], references: [id])
  clientId       String
  client         HolisticUser        @relation(fields: [clientId], references: [id])
  practitionerId String
  practitioner   Practitioner        @relation(fields: [practitionerId], references: [id])
  rating         Int                 // 1-5
  comment        String?
  status         String              @default("PENDING") // PENDING | APPROVED | REJECTED
  submittedAt    DateTime            @default(now())
  approvedAt     DateTime?
}

model HolisticNotification {
  id            String               @id @default(cuid())
  userId        String
  user          HolisticUser         @relation(fields: [userId], references: [id])
  appointmentId String?
  appointment   HolisticAppointment? @relation(fields: [appointmentId], references: [id])
  type          String               // BOOKING_CONFIRM | REMINDER_24H | REMINDER_1H | VIDEO_LINK | CANCELLATION | PAYOUT
  channel       String               // EMAIL | SMS
  sentAt        DateTime?
  status        String               @default("PENDING") // PENDING | SENT | FAILED
  createdAt     DateTime             @default(now())
}
